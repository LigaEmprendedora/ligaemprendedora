---
const navItems = [
  { href: '/#hero', label: 'Inicio' },
  { href: '/#vestuario', label: 'El Vestuario' },
  { href: '/#doble-motor', label: 'Método' },
  { href: '/#fichajes', label: 'Fichajes' },
  { href: '/#faq-var', label: 'FAQ' },
  { href: '/newsletter', label: 'Newsletter' },
];
---

<header id="site-header" class="site-header fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-0 md:px-6">
    <a href="/#hero" class="flex items-center gap-2" aria-label="Ir al inicio de Liga Emprendedora">
      <img
        src="/Logo_liga2.webp"
        alt="Logo Liga Emprendedora"
        class="h-22 w-auto"
      />
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-white/80 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="transition hover:text-white">
          {item.label}
        </a>
      ))}

      <a
        href="/#pitazo-final"
        class="rounded-full bg-[#e0f459] px-4 py-2 text-sm font-semibold text-[#162741] shadow-[0_0_22px_rgba(224,244,89,0.18)] transition hover:shadow-[0_0_30px_rgba(224,244,89,0.28)]"
      >
        Únete
      </a>
    </nav>

    <button
      type="button"
      id="mobile-menu-button"
      class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 md:hidden"
      aria-label="Abrir menú"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <div class="space-y-1.5">
        <span class="block h-0.5 w-4 rounded-full bg-white"></span>
        <span class="block h-0.5 w-4 rounded-full bg-white"></span>
        <span class="block h-0.5 w-4 rounded-full bg-white"></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/8 bg-[#162741]/95 backdrop-blur-md md:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-4 md:px-6">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-xl px-3 py-2 text-sm font-medium text-white/90 transition hover:bg-white/5 hover:text-white"
          data-mobile-link
        >
          {item.label}
        </a>
      ))}

      <a
        href="/#pitazo-final"
        class="mt-2 inline-flex items-center justify-center rounded-full bg-[#e0f459] px-4 py-2.5 text-sm font-semibold text-[#162741] shadow-[0_0_22px_rgba(224,244,89,0.18)] transition hover:shadow-[0_0_30px_rgba(224,244,89,0.28)]"
        data-mobile-link
      >
        Únete
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  .site-header.is-scrolled {
    background: rgba(22, 39, 65, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('site-header');
    const openBtn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('[data-mobile-link]');

    if (!header) return;

    const updateHeaderOnScroll = () => {
      if (window.scrollY > 24) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    };

    updateHeaderOnScroll();
    window.addEventListener('scroll', updateHeaderOnScroll);

    if (!openBtn || !menu) return;

    const toggleMenu = () => {
      menu.classList.toggle('hidden');
      const expanded = openBtn.getAttribute('aria-expanded') === 'true';
      openBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    };

    openBtn.addEventListener('click', toggleMenu);

    links.forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        openBtn.setAttribute('aria-expanded', 'false');
      });
    });
  });
</script>