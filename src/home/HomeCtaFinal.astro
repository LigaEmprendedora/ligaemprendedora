---
const arsenalItems = [
  {
    title: "El Escáner del DT",
    text: "La matriz implacable para validar si tu idea es rentable o te va a quebrar.",
  },
  {
    title: "La Alineación Táctica",
    text: "Estructura de costos a prueba de balas. Si los números no dan, no sales.",
  },
  {
    title: "El Club MVP90",
    text: "Acceso a nuestra comunidad privada de WhatsApp. Participa en retos de ejecución, livestácticos y no vuelvas a jugar solo.",
  },
  {
    title: "15 herramientas gerenciales más",
    text: "Plantillas, listas de chequeo y documentos premium listos para descargar y aplicar hoy.",
  },
];
---

<section id="bunker" class="relative isolate overflow-hidden bg-[#f6f5f2] px-4 py-20 text-[#162741] md:px-6 md:py-28">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,#ffffff_0%,#f6f5f2_100%)]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-[#162741]/8"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-[#162741]/8"></div>
    <div class="absolute -left-16 top-12 h-64 w-64 rounded-full bg-[#162741]/4 blur-3xl"></div>
    <div class="absolute right-0 top-16 h-72 w-72 rounded-full bg-[#E1C875]/12 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/2 h-56 w-56 -translate-x-1/2 rounded-full bg-[#162741]/4 blur-3xl"></div>
  </div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.02fr_0.98fr] lg:gap-16">
    <div class="max-w-3xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-[#9a8954] md:text-xs">
        El búnker · Arsenal táctico
      </p>

      <h2 class="mt-5 text-[2.35rem] font-extrabold leading-[1.02] tracking-[-0.045em] text-[#162741] sm:text-5xl md:text-6xl">
        18 Herramientas de Combate y un Vestuario Activo. No compras un libro, adquieres un ecosistema.
      </h2>

      <p class="mt-7 max-w-2xl text-base leading-8 text-[#334865] md:text-[1.12rem] md:leading-9">
        Con tu pase a <span class="font-semibold text-[#162741]">Emprende Futbolero</span>, desbloqueas la bóveda privada.
        Un vistazo a tu arsenal:
      </p>

      <div class="mt-8 space-y-4">
        {arsenalItems.map((item) => (
          <div class="flex items-start gap-4 rounded-3xl border border-[#162741]/8 bg-white/80 px-5 py-5 shadow-[0_14px_40px_rgba(22,39,65,0.06)] backdrop-blur-sm">
            <span class="mt-1 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#E1C875]/55 bg-[#E1C875]/16 text-[#9a8954] shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l1.8 4.2L18 9l-3.1 2.9.8 4.6L12 14.8 8.3 16.5l.8-4.6L6 9l4.2-1.8L12 3z" />
              </svg>
            </span>

            <div>
              <h3 class="text-lg font-extrabold tracking-[-0.02em] text-[#162741] md:text-[1.2rem]">
                <span class="text-[#9a8954]">●</span> {item.title}
              </h3>
              <p class="mt-2 text-sm leading-7 text-[#334865] md:text-[1rem] md:leading-8">
                {item.text}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a
          href="/unete"
          class="inline-flex min-h-[58px] items-center justify-center rounded-full bg-[#e0f459] px-8 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_26px_rgba(224,244,89,0.24)] transition hover:-translate-y-px hover:shadow-[0_0_38px_rgba(224,244,89,0.34)]"
        >
          Quiero mi arsenal y el libro ahora
        </a>
      </div>
    </div>

    <div class="relative flex items-center justify-center lg:justify-end">
      <div class="relative h-[520px] w-full max-w-[560px]">
        <div class="absolute left-6 top-16 h-[350px] w-[250px] rotate-[-11deg] rounded-[28px] border border-[#162741]/10 bg-white shadow-[0_24px_70px_rgba(22,39,65,0.12)]">
          <div class="border-b border-[#162741]/8 px-5 py-4">
            <div class="flex items-center justify-between">
              <p class="text-[10px] font-extrabold uppercase tracking-[0.24em] text-[#9a8954]">Escáner del DT</p>
              <span class="rounded-full bg-[#E1C875]/16 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-[#9a8954]">Matriz</span>
            </div>
          </div>
          <div class="space-y-4 px-5 py-5">
            <div class="grid grid-cols-4 gap-2">
              {Array.from({ length: 16 }).map(() => (
                <span class="h-7 rounded-md border border-[#162741]/8 bg-[#162741]/4"></span>
              ))}
            </div>
            <div class="rounded-2xl border border-[#162741]/8 bg-[#f6f5f2] p-4">
              <div class="h-2 w-24 rounded-full bg-[#162741]/12"></div>
              <div class="mt-3 h-2 w-full rounded-full bg-[#162741]/8"></div>
              <div class="mt-2 h-2 w-4/5 rounded-full bg-[#162741]/8"></div>
              <div class="mt-2 h-2 w-3/5 rounded-full bg-[#E1C875]/30"></div>
            </div>
          </div>
        </div>

        <div class="absolute right-8 top-2 z-20 h-[360px] w-[270px] rotate-[8deg] rounded-[30px] border border-[#162741]/10 bg-white shadow-[0_28px_90px_rgba(22,39,65,0.16)]">
          <div class="border-b border-[#162741]/8 px-5 py-4">
            <div class="flex items-center justify-between">
              <p class="text-[10px] font-extrabold uppercase tracking-[0.24em] text-[#9a8954]">Alineación táctica</p>
              <span class="rounded-full bg-[#162741] px-2 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-white">Costos</span>
            </div>
          </div>
          <div class="space-y-4 px-5 py-5">
            <div class="rounded-[22px] border border-[#162741]/8 bg-[#f8fafc] p-4">
              <div class="flex items-end gap-3">
                <span class="h-14 w-8 rounded-t-xl bg-[#162741]/12"></span>
                <span class="h-20 w-8 rounded-t-xl bg-[#162741]/18"></span>
                <span class="h-28 w-8 rounded-t-xl bg-[#E1C875]/65"></span>
                <span class="h-16 w-8 rounded-t-xl bg-[#162741]/12"></span>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-between rounded-2xl border border-[#162741]/8 px-3 py-3">
                <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#162741]">Margen</span>
                <span class="text-sm font-extrabold text-[#162741]">18.4%</span>
              </div>
              <div class="flex items-center justify-between rounded-2xl border border-[#162741]/8 px-3 py-3">
                <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#162741]">Punto de equilibrio</span>
                <span class="text-sm font-extrabold text-[#162741]">Mes 4</span>
              </div>
            </div>
          </div>
        </div>

        <div class="absolute bottom-0 left-20 z-30 w-[320px] rounded-4xl border border-[#162741]/10 bg-[#162741] p-6 text-white shadow-[0_30px_90px_rgba(22,39,65,0.28)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-[10px] font-extrabold uppercase tracking-[0.28em] text-[#E1C875]">Club MVP90</p>
              <p class="mt-2 text-2xl font-extrabold tracking-[-0.03em] text-white">Vestuario activo</p>
            </div>
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#e0f459] text-[#162741] shadow-[0_0_20px_rgba(224,244,89,0.28)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 10h10M7 14h6m6-5.5a2.5 2.5 0 01-2.5 2.5H8l-3 2.5V8.5A2.5 2.5 0 017.5 6h9A2.5 2.5 0 0119 8.5z" />
              </svg>
            </span>
          </div>

          <div class="mt-6 space-y-3">
            <div class="rounded-2xl border border-white/10 bg-white/6 px-4 py-3">
              <p class="text-sm font-semibold text-white">Retos de ejecución semanales</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/6 px-4 py-3">
              <p class="text-sm font-semibold text-white">Livestácticos y feedback real</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/6 px-4 py-3">
              <p class="text-sm font-semibold text-white">No vuelves a jugar solo</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
