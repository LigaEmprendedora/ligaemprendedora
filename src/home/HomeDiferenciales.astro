  {
    name: "Pack Jugador Élite",
    kicker: "Para los que quieren la táctica",
    priceLabel: "Digital",
    featured: false,
    premium: false,
    items: [
      "Libro Emprende Futbolero (Formato 100% Digital).",
      'Acceso al "Búnker Digital": 15 plantillas y 3 checklists.',
    ],
    cta: "Entrar a la Cantera",
    microcopy: "Disponible para todo el mundo. Acceso inmediato.",
  },
  {
    name: "Pack Capitán",
    kicker: "Para los que entran a ganar",
    priceLabel: "Físico + Digital",
    featured: true,
    premium: false,
    items: [
      "Todo lo del Pack Jugador Élite incluido +",
      "Libro Emprende Futbolero (Edición Física).",
      "Búnker Digital completo (18 herramientas).",
      "Pase al Club MVP90 · Comunidad, retos y lives.",
      "Suscripción al Newsletter Táctico Semanal.",
      "Masterclass grabada: financiarte con cero presupuesto.",
    ],
    cta: "Ponerme la Cinta de Capitán",
    microcopy: "➕ Pack adicional. Requiere tener el Pack Jugador Élite activo.",
  },
  {
    name: "Pack DT",
    kicker: "Para los que van a dirigir",
    priceLabel: "VIP",
    featured: false,
    premium: true,
    items: [
      "Todo lo del Pack Capitán incluido.",
      "Libro físico firmado por el autor.",
      "Consultoría 1:1 · Sesión táctica privada de 45 min con Oswaldo Vega.",
      "Encuentro de camerino · Q&A en vivo con los 50 DTs.",
    ],
    cta: "Fichar como DT hoy",
    microcopy:
      "➕ Pack adicional. Requiere tener el Pack Jugador Élite activo. Las mentorías virtuales aplican para todo el mundo.",
  },
];

const amazonLinks = [
  { label: "Estados Unidos y el resto de Latinoamérica", href: "http://amazon.com/dp/B0GX3B9FYN/" },
  { label: "México", href: "https://www.amazon.com.mx/dp/B0GX3B9FYN/" },
  { label: "España", href: "https://www.amazon.es/dp/B0GX3B9FYN/" },
];

const buscalibreLinks = [
  { label: "Colombia", href: "#" },
  { label: "México", href: "#" },
  { label: "Perú", href: "#" },
  { label: "Ecuador", href: "#" },
  { label: "Chile", href: "#" },
  { label: "Argentina", href: "#" },
  { label: "Uruguay", href: "#" },
];
---

<section id="fichajes"  class="relative isolate overflow-hidden bg-[#162741] px-4 py-20 text-white md:px-6 md:py-28">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,#162741_0%,#132238_100%)]"></div>
    <div class="absolute left-[-6%] top-12 h-72 w-72 rounded-full bg-[#e0f459]/8 blur-3xl"></div>
    <div class="absolute right-[-8%] top-0 h-96 w-96 rounded-full bg-[#E1C875]/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-white/4 blur-3xl"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-white/8"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-white/8"></div>
  </div>

  

  <div class="relative mx-auto max-w-7xl">
<!-- HEADER MEJORADO: Compra Emprende Futbolero -->
<div class="relative  px-8 pb-10 pt-12 text-center md:px-10 md:pb-14 md:pt-16">
 
  <!-- Glows ambientales -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-[-60px] h-[200px] w-[420px] -translate-x-1/2 rounded-full bg-[#e0f459]/12 blur-3xl"></div>
    <div class="absolute bottom-[-30px] left-[-60px] h-[260px] w-[260px] rounded-full bg-[#E1C875]/8 blur-3xl"></div>
  </div>
 
  <!-- Pill "Disponible ahora" -->
  <div class="relative mb-6 inline-flex items-center gap-2.5 rounded-full border border-[#e0f459]/22 bg-[#e0f459]/8 px-5 py-2">
    <span class="ef-dot h-2 w-2 rounded-full bg-[#e0f459]"></span>
    <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e0f459]">
      Sepáralo
    </span>
  </div>
 
  <!-- Título principal -->
  <div class="relative">
    <span class="mb-1 block text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E1C875]/70 md:text-xs">
      el libro
    </span>
    <h2 class="ef-title block font-extrabold leading-[0.92]  tracking-tight text-white">
      Emprende&nbsp; <span class="text-[#e0f459]">Futbolero</span>
    </h2>
    <!-- Línea decorativa debajo del título -->
    <div class="mx-auto mt-3 h-[3px] w-48 rounded-full bg-linear-to-r from-transparent via-[#e0f459] to-[#E1C875] opacity-70 md:w-64"></div>
  </div>
 
  <!-- Subtítulo -->
  <p class="relative mx-auto mt-5 max-w-sm text-base leading-7 text-white/60 md:text-[1.05rem]">
    Elige tu <span class="font-semibold text-white/88">plataforma</span> y el país donde lo quieres recibir.
  </p>
 
  <!-- Divisor con balón -->
  <div class="relative mx-auto mt-8 flex max-w-xs items-center gap-4">
    <div class="h-px flex-1 bg-linear-to-r from-transparent to-white/12"></div>
    <div class="flex items-center gap-2">
      <!-- Balón SVG inline -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="opacity-55">
        <circle cx="12" cy="12" r="10" stroke="#E1C875" stroke-width="1.5"/>
        <path d="M12 2C12 2 9 6 9 12C9 18 12 22 12 22" stroke="#E1C875" stroke-width="1.2"/>
        <path d="M12 2C12 2 15 6 15 12C15 18 12 22 12 22" stroke="#E1C875" stroke-width="1.2"/>
        <path d="M2 12H22" stroke="#E1C875" stroke-width="1.2"/>
        <path d="M3.5 7H20.5" stroke="#E1C875" stroke-width="1"/>
        <path d="M3.5 17H20.5" stroke="#E1C875" stroke-width="1"/>
      </svg>
      <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#E1C875]/55">
        Selecciona tu tienda
      </span>
    </div>
    <div class="h-px flex-1 bg-linear-to-l from-transparent to-white/12"></div>
  </div>
 
</div>


     
    <div id="compra-libro" class="mt-2 overflow-hidden rounded-[30px] border border-white/14 bg-white shadow-[0_28px_90px_rgba(0,0,0,0.24)]">  

      
      

     
      <div class="grid divide-y divide-[#162741]/8 md:grid-cols-2 md:divide-x md:divide-y-0">

       
        <div class="px-8 py-7 md:px-10">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-9  items-center justify-center rounded-xl  overflow-hidden">
  <img src="/amazon-logo.webp" alt="Amazon" class="h-10  object-contain" />
</div>
            <span class="rounded-full border border-[#162741]/10 bg-[#162741]/5 px-2.5 py-1 text-[10px] font-semibold text-[#162741]/60">
              Digital · Tapa blanda · Tapa dura
            </span>
          </div>
          <div class="space-y-2">
            {amazonLinks.map((item) => (
              <a
                href={item.href}
                target="_blank"
                class="group flex items-center justify-between rounded-2xl border border-[#162741]/8 bg-[#162741]/3 px-4 py-3 transition hover:border-[#162741]/16 hover:bg-[#162741]/7"
              >
                <span class="text-sm font-semibold text-[#162741]">{item.label}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-[#162741]/30 transition group-hover:text-[#162741]/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            ))}
          </div>
        </div>

      
        <div class="px-8 py-7 md:px-10">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-9  items-center justify-center rounded-xl  overflow-hidden">
  <img src="/buscalibre-logo.webp" alt="Buscalibre" class="h-10  object-contain" />
</div>
            <span class="rounded-full border border-[#162741]/10 bg-[#162741]/5 px-2.5 py-1 text-[10px] font-semibold text-[#162741]/60">
               Tapa blanda 
            </span>
          </div>
          <div class="grid grid-cols-2 gap-2">
            {buscalibreLinks.map((item) => (
              <a
                href={item.href}
                target="_blank"
                class="group flex items-center justify-between rounded-2xl border border-[#162741]/8 bg-[#162741]/3 px-4 py-3 transition hover:border-[#162741]/16 hover:bg-[#162741]/7"
              >
                <span class="text-sm font-semibold text-[#162741]">{item.label}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 text-[#162741]/30 transition group-hover:text-[#162741]/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            ))}
          </div>
        </div>
     

      </div>
      
    </div>
  </div>
</section>

<style>
  /* Pulso del dot verde */
  .ef-dot {
    animation: ef-pulse 2s ease-in-out infinite;
  }
  @keyframes ef-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.65); }
  }
 
  /* Tamaño del título con clamp para responsivo */
  .ef-title {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
  }
</style>
 