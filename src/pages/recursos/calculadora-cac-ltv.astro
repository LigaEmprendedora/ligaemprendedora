---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Calculadora de CAC y LTV | Liga Emprendedora";
const pageDescription =
  "Plantilla en Excel/Sheets para calcular CAC, LTV y la salud real de tu adquisición.";
const downloadLink = "https://docs.google.com/spreadsheets/d/18iVVoT1VRVgQg4dTg-HBdsUyu6UAl9AY/edit?usp=sharing";

const bullets = [
  "CAC por canal para saber qué sí paga el partido.",
  "LTV estimado por cliente o segmento con supuestos simples.",
  "Relación LTV/CAC para detectar si tu crecimiento se sostiene.",
  "Sensibilidad de ticket, margen y retención sin volverte financiero.",
];

const signals = [
  { label: "Útil para", value: "Founders, growth y ventas" },
  { label: "Formato", value: "Excel + Google Sheets" },
  { label: "Tiempo", value: "15 minutos" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(225,200,117,0.18),transparent_28%),radial-gradient(circle_at_top_right,rgba(224,244,89,0.10),transparent_20%),linear-gradient(180deg,rgba(255,255,255,0.03)_0%,rgba(22,39,65,0)_42%)]"></div>
          <div class="absolute -left-10 top-10 h-52 w-52 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-[#e0f459]/10 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">
              Recursos · Finanzas de cancha
            </p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">
              Calculadora de CAC y LTV para dejar de crecer a ciegas.
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">
              Entiende cuánto te cuesta meter un nuevo cliente al camerino y cuánto valor te deja en el tiempo. Esta plantilla te ayuda a tomar decisiones con números útiles, no con humo.
            </p>

            <div class="mt-8 grid gap-3 sm:grid-cols-3">
              {signals.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
                  <p class="text-[10px] uppercase tracking-[0.2em] text-white/55">{item.label}</p>
                  <p class="mt-2 text-sm font-semibold text-white">{item.value}</p>
                </div>
              ))}
            </div>
          </div>

          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">Qué desbloqueas</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">
              {bullets.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="#descarga-cac-ltv"
              class="mt-6 inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_30px_rgba(224,244,89,0.18)] transition hover:-translate-y-px hover:shadow-[0_0_40px_rgba(224,244,89,0.28)]"
            >
              Quiero la plantilla
            </a>
          </aside>
        </div>
      </section>

      <section id="descarga-cac-ltv" class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,1.05fr)_420px]">
          <div class="space-y-6">
            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
                Qué podrás analizar
              </p>

              <div class="mt-5 grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">
                    Punto 1
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[#334865]">
                    <strong class="text-[#162741]">CAC por canal</strong> para saber qué canal sí está pagando el partido.
                    Vas a ver cuánto te cuesta conseguir un cliente en cada canal, como pauta, redes, referidos o ventas directas.
                  </p>
                </div>

                <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">
                    Punto 2
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[#334865]">
                    <strong class="text-[#162741]">LTV estimado por cliente o segmento</strong> con supuestos simples.
                    Vas a calcular cuánto valor puede dejarte un cliente a lo largo del tiempo, sin necesidad de montar un modelo complicado.
                  </p>
                </div>

                <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">
                    Punto 3
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[#334865]">
                    <strong class="text-[#162741]">Relación LTV/CAC</strong> para detectar si tu crecimiento se sostiene.
                    Vas a comparar cuánto te deja un cliente versus cuánto te costó conseguirlo, para entender si estás creciendo con sentido o perdiendo plata.
                  </p>
                </div>

                <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">
                    Punto 4
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[#334865]">
                    <strong class="text-[#162741]">Sensibilidad de ticket, margen y retención</strong> sin volverte financiero.
                    Vas a probar qué pasa si cambian variables clave como el precio promedio, la ganancia por venta o el tiempo que un cliente se queda contigo.
                  </p>
                </div>
              </div>

              <p class="mt-5 text-sm leading-7 text-[#52657e]">
                El objetivo no es hacer un modelo financiero eterno. Es darte un tablero claro para saber si tu adquisición tiene sentido hoy, cuánto te deja realmente cada cliente y qué palanca deberías mover primero.
              </p>

              <div class="mt-6 rounded-2xl border border-[#162741]/8 bg-[#f8fafc] p-5">
                <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">
                  Glosario rápido
                </p>

                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  <div>
                    <p class="text-sm font-bold text-[#162741]">CAC</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Costo de adquisición de cliente. Es lo que gastas para conseguir un cliente nuevo.
                    </p>
                  </div>

                  <div>
                    <p class="text-sm font-bold text-[#162741]">LTV</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Valor del cliente en el tiempo. Es lo que te deja un cliente durante toda su relación con tu negocio.
                    </p>
                  </div>

                  <div>
                    <p class="text-sm font-bold text-[#162741]">Canal</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Medio por el que llega un cliente, como Instagram, pauta, referidos o WhatsApp.
                    </p>
                  </div>

                  <div>
                    <p class="text-sm font-bold text-[#162741]">Ticket</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Valor promedio de compra de un cliente.
                    </p>
                  </div>

                  <div>
                    <p class="text-sm font-bold text-[#162741]">Margen</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Ganancia que te queda después de cubrir los costos de vender.
                    </p>
                  </div>

                  <div>
                    <p class="text-sm font-bold text-[#162741]">Retención</p>
                    <p class="text-sm leading-7 text-[#52657e]">
                      Tiempo o frecuencia con la que un cliente sigue comprándote.
                    </p>
                  </div>
                </div>
              </div>
            </article>

            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <h2 class="text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">
                Cómo usarla sin enredarte
              </h2>
              <div class="mt-6 space-y-5 text-sm leading-7 text-[#334865]">
                <div>
                  <p class="font-bold text-[#162741]">1. Mete tus gastos reales de adquisición.</p>
                  <p class="mt-1">
                    Publicidad, comisiones, herramientas, equipo comercial o cualquier costo que realmente estés usando para captar demanda.
                  </p>
                </div>
                <div>
                  <p class="font-bold text-[#162741]">2. Define ticket, margen y permanencia.</p>
                  <p class="mt-1">
                    Con tres variables bien estimadas, la plantilla te muestra si estás jugando un partido rentable o solo inflando vanity metrics.
                  </p>
                </div>
                <div>
                  <p class="font-bold text-[#162741]">3. Compara escenarios.</p>
                  <p class="mt-1">
                    Sube o baja retención, ticket o CAC y entiende dónde está la palanca más poderosa antes de gastar más caja.
                  </p>
                </div>
              </div>
            </article>
          </div>

          <aside class="rounded-4xl border border-[#162741]/10 bg-white p-7 shadow-[0_24px_80px_rgba(22,39,65,0.08)] md:p-8 lg:sticky lg:top-28">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
              Acceso inmediato
            </p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">
              Descarga gratis la calculadora
            </h2>
            <p class="mt-3 text-sm leading-7 text-[#52657e]">
              Déjanos tus datos y verás el enlace directo de descarga al instante.
            </p>

            <form
              class="mt-6 space-y-4"
              name="calculadora-cac-ltv"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              data-download-link={downloadLink}
              data-resource-form
            >
              <input type="hidden" name="form-name" value="calculadora-cac-ltv" />
              <p class="hidden"><label>No llenar: <input name="bot-field" /></label></p>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Nombre completo*</label>
                <input
                  type="text"
                  name="nombre"
                  required
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Email*</label>
                <input
                  type="email"
                  name="email"
                  required
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Nombre de la empresa</label>
                <input
                  type="text"
                  name="empresa"
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Teléfono</label>
                <input
                  type="tel"
                  name="telefono"
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <button
                type="submit"
                class="inline-flex min-h-[54px] w-full items-center justify-center rounded-full bg-[#e0f459] px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_28px_rgba(224,244,89,0.18)] transition hover:-translate-y-px hover:shadow-[0_0_36px_rgba(224,244,89,0.3)]"
              >
                Descargar recurso
              </button>

              <p class="text-[11px] leading-5 text-[#6b7280]">
                Sin spam. Solo recursos, herramientas y tácticas de negocio de la Liga.
              </p>

              <p class="text-xs text-[#667085]">
                Al continuar, aceptas nuestros
                <a href="/terminos" class="underline">Términos y Condiciones</a>
                y nuestra
                <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.
              </p>

              <div
                class="hidden rounded-2xl bg-[#ecfdf3] px-4 py-4 text-sm text-[#14532d]"
                data-download-message
              ></div>
            </form>
          </aside>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>