---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Plan de Negocio One-Page | Liga Emprendedora";
const pageDescription = "Plantilla simple y accionable para definir tu negocio en una sola hoja.";
const downloadLink = "https://docs.google.com/spreadsheets/d/15rGW4_qT589XpPr6FhJ98K0F8QaZ9rJ6-xhIRWYugU0/edit?usp=sharing";
const scriptUrl = "https://script.google.com/macros/s/AKfycbz4BZPlvEa1-78yTjp6nBdGH9-UCP02lK2VRrFUA7iSX4It2ODw6nR0_TsMmxabTD52tg/exec";
const pillars = [
  "Objetivo del partido a 90 días.",
  "Cliente ideal, problema central y propuesta de valor.",
  "Modelo de negocio, canales y KPIs clave.",
  "Próximas jugadas claras para la siguiente semana.",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(225,200,117,0.16),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(224,244,89,0.08),transparent_24%)]"></div>
          <div class="absolute left-10 top-10 h-56 w-56 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>
        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">Recursos · Estrategia en una hoja</p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">Tu plan de negocio no tiene que ser eterno para ser útil.</h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">Esta plantilla condensa la jugada completa en una sola página: a quién le vendes, qué problema resuelves, cómo ganas dinero y qué métricas importan de verdad.</p>
            <div class="mt-8 flex flex-wrap gap-3 text-sm text-white/78">
              <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">1 hoja</span>
              <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">90 días de foco</span>
              <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">Ideal para founders y equipos pequeños</span>
            </div>
          </div>
          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">Incluye</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">
              {pillars.map((item) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>{item}</span></li>)}
            </ul>
            <a href="#descarga-plan" class="mt-6 inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Quiero la plantilla</a>
          </aside>
        </div>
      </section>

      <section id="descarga-plan" class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,1.05fr)_420px]">
          <div class="space-y-6">
            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <h2 class="text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Qué resuelve esta herramienta</h2>
              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                {pillars.map((item, index) => (
                  <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">Bloque {index + 1}</p>
                    <p class="mt-2 text-sm leading-7 text-[#334865]">{item}</p>
                  </div>
                ))}
              </div>
              <p class="mt-5 text-sm leading-7 text-[#52657e]">Es la herramienta ideal cuando necesitas claridad táctica, no un PDF infinito que nadie vuelve a mirar.</p>
            </article>

            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <h2 class="text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Cómo aprovecharla mejor</h2>
              <div class="mt-6 space-y-5 text-sm leading-7 text-[#334865]">
                <p><span class="font-bold text-[#162741]">Empieza por la meta.</span> Define qué significa ganar en 90 días antes de llenar los demás bloques.</p>
                <p><span class="font-bold text-[#162741]">Escribe simple.</span> Si una idea no cabe en una frase clara, todavía está verde.</p>
                <p><span class="font-bold text-[#162741]">Revisa semanalmente.</span> Esta hoja sirve como tablero de partido, no como documento para archivar.</p>
              </div>
            </article>
          </div>

          <aside class="rounded-4xl border border-[#162741]/10 bg-white p-7 shadow-[0_24px_80px_rgba(22,39,65,0.08)] md:p-8 lg:sticky lg:top-28">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">Acceso inmediato</p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Descarga gratis el one-page</h2>
            <p class="mt-3 text-sm leading-7 text-[#52657e]">Déjanos tus datos y te mostramos el enlace de descarga al instante.</p>
            <form class="mt-6 space-y-4" name="plan-negocio-one-page" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-download-link={downloadLink} data-resource-form>
              <input type="hidden" name="form-name" value="plan-negocio-one-page" />
              <p class="hidden"><label>No llenar: <input name="bot-field" /></label></p>
              <div><label class="block text-xs font-semibold text-[#4b5563]">Nombre completo*</label><input type="text" name="nombre" required class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
              <div><label class="block text-xs font-semibold text-[#4b5563]">Email*</label><input type="email" name="email" required class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
              <div><label class="block text-xs font-semibold text-[#4b5563]">Nombre de la empresa</label><input type="text" name="empresa" class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
              <div><label class="block text-xs font-semibold text-[#4b5563]">Teléfono</label><input type="tel" name="telefono" class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
              <button type="submit" class="inline-flex min-h-[54px] w-full items-center justify-center rounded-full bg-[#e0f459] px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Descargar recurso</button>
              <p class="text-xs text-[#667085]">
  Al continuar, aceptas nuestros
  <a href="/terminos" class="underline">Términos y Condiciones</a>
  y nuestra
  <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.
</p>
              <div class="hidden rounded-2xl bg-[#ecfdf3] px-4 py-4 text-sm text-[#14532d]" data-download-message></div>
            </form>
          </aside>
        </div>
      </section>
    </main>
    <Footer />
  </div>

  
</BaseLayout>
