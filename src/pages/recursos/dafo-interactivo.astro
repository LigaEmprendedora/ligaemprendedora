---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Análisis DAFO Interactivo | Liga Emprendedora";
const pageDescription = "Plantilla interactiva DAFO para identificar fortalezas, debilidades, oportunidades y amenazas.";
const downloadLink = "https://docs.google.com/spreadsheets/d/1ICiImpEt3Y3yYY5iRNt7niyKOtBr7sZm6Z1v1UjL0m0/edit?usp=sharing";
const scriptUrl = "https://script.google.com/macros/s/AKfycbz4BZPlvEa1-78yTjp6nBdGH9-UCP02lK2VRrFUA7iSX4It2ODw6nR0_TsMmxabTD52tg/exec";
const sections = [
  { title: "Fortalezas", hint: "Qué ya haces bien y te da ventaja.", tone: "from-[#e0f459]/25 to-white" },
  { title: "Debilidades", hint: "Qué está rompiendo ritmo o calidad.", tone: "from-[#162741]/10 to-white" },
  { title: "Oportunidades", hint: "Ventanas de mercado que aún no capitalizas.", tone: "from-[#E1C875]/25 to-white" },
  { title: "Amenazas", hint: "Riesgos externos que pueden cortarte el juego.", tone: "from-[#f7d5cf] to-white" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />
    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(225,200,117,0.16),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(224,244,89,0.08),transparent_22%)]"></div>
          <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>
        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">Recursos · Diagnóstico estratégico</p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">Hazte una radiografía honesta antes de patear más fuerte.</h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">Este DAFO te ayuda a ordenar la cabeza, ver el partido completo y decidir dónde enfocar tu energía durante los próximos 30 a 90 días.</p>
          </div>
          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">Qué obtienes</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Matriz clara para diagnosticar tu momento actual.</span></li>
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Descargable para seguir trabajándolo fuera de la web.</span></li>
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Lenguaje simple para fundadores y equipos pequeños.</span></li>
            </ul>
            <a href="#descarga-dafo" class="mt-6 inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Quiero la plantilla</a>
          </aside>
        </div>
      </section>

      <section class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto max-w-7xl">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_380px]">
            <div>
              <div class="grid gap-5 md:grid-cols-2">
                {sections.map((item) => (
                  <article class={`rounded-[28px] border border-[#162741]/10 bg-linear-to-br ${item.tone} p-5 shadow-[0_18px_60px_rgba(22,39,65,0.06)]`}>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a8954]">Bloque</p>
                    <h2 class="mt-2 text-xl font-extrabold tracking-[-0.03em] text-[#162741]">{item.title}</h2>
                    <p class="mt-2 text-sm leading-7 text-[#52657e]">{item.hint}</p>
                    <textarea class="mt-4 h-44 w-full rounded-2xl border border-[#162741]/10 bg-white/70 px-4 py-3 text-sm outline-none transition focus:border-[#162741]" placeholder={`Escribe aquí tus ${item.title.toLowerCase()}...`}></textarea>
                  </article>
                ))}
              </div>

              <article class="mt-6 rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
                <h2 class="text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Cómo leer tu DAFO</h2>
                <div class="mt-6 space-y-4 text-sm leading-7 text-[#334865]">
                  <p><span class="font-bold text-[#162741]">No busques quedar bonito.</span> Este ejercicio funciona cuando eres brutalmente honesto con lo que hoy sí y no está funcionando.</p>
                  <p><span class="font-bold text-[#162741]">Conecta bloques.</span> La verdadera jugada sale de usar una fortaleza para capturar una oportunidad o de corregir una debilidad antes de que una amenaza te golpee.</p>
                  <p><span class="font-bold text-[#162741]">Termina con acción.</span> El diagnóstico debe convertirse en prioridades concretas para los próximos 30 días.</p>
                </div>
              </article>
            </div>

            <aside id="descarga-dafo" class="rounded-4xl border border-[#162741]/10 bg-white p-7 shadow-[0_24px_80px_rgba(22,39,65,0.08)] md:p-8 lg:sticky lg:top-28">
              <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">Acceso inmediato</p>
              <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Descarga gratis la plantilla</h2>
              <p class="mt-3 text-sm leading-7 text-[#52657e]">Si quieres seguir trabajándola offline, deja tus datos y te mostramos el enlace directo.</p>
              <form class="mt-6 space-y-4" name="dafo-interactivo" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-download-link={downloadLink} data-resource-form>
                <input type="hidden" name="form-name" value="dafo-interactivo" />
                <p class="hidden"><label>No llenar: <input name="bot-field" /></label></p>
                <div><label class="block text-xs font-semibold text-[#4b5563]">Nombre completo*</label><input type="text" name="nombre" required class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
                <div><label class="block text-xs font-semibold text-[#4b5563]">Email*</label><input type="email" name="email" required class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
                <div><label class="block text-xs font-semibold text-[#4b5563]">Nombre de la empresa</label><input type="text" name="empresa" class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
                <div><label class="block text-xs font-semibold text-[#4b5563]">Teléfono</label><input type="tel" name="telefono" class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]" /></div>
                <button type="submit" class="inline-flex min-h-[54px] w-full items-center justify-center rounded-full bg-[#e0f459] px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Descargar recurso</button>
                <p class="text-xs text-[#667085]">
  Al continuar, aceptas nuestros
  <a href="/terminos" class="underline">Términos y Condiciones</a>
  y nuestra
  <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.
</p>
                <div class="hidden rounded-2xl bg-[#ecfdf3] px-4 py-4 text-sm text-[#14532d]" data-download-message></div>
              </form>
            </aside>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </div>
 
</BaseLayout>
