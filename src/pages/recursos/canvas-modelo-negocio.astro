---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Canvas de Modelo de Negocio | Liga Emprendedora";
const pageDescription = "Canvas visual e interactivo para bajar tu modelo de negocio a tierra.";
const blocks = [
  ["Segmentos de Cliente", "¿Para quién creas valor?"],
  ["Propuesta de Valor", "¿Qué problema resuelves y qué resultado entregas?"],
  ["Canales", "¿Cómo llegas al cliente?"],
  ["Relación con Clientes", "¿Cómo captas, atiendes y retienes?"],
  ["Fuentes de Ingreso", "¿Cómo entra el dinero?"],
  ["Recursos Clave", "¿Qué activos necesitas para operar?"],
  ["Actividades Clave", "¿Qué debe funcionar sí o sí?"],
  ["Socios Clave", "¿Quién te ayuda a ejecutar mejor?"],
  ["Estructura de Costos", "¿Qué te cuesta sostener el modelo?"],
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />
    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(225,200,117,0.18),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(224,244,89,0.10),transparent_24%)]"></div>
          <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>
        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">Recursos · Modelo de negocio</p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">Baja tu idea a tierra sin perderte en 30 páginas.</h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">Llena tu canvas aquí mismo y revisa si tu modelo se sostiene: cliente, propuesta, canales, ingresos, costos y las piezas que de verdad hacen jugar al negocio.</p>
          </div>
          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">Cómo usarlo</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Llena primero lo que hoy sí sabes.</span></li>
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Genera un diagnóstico rápido para ver vacíos.</span></li>
              <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>Descarga tu borrador y síguelo iterando.</span></li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto max-w-7xl">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
            <div>
              <div class="grid gap-5 md:grid-cols-3">
                {blocks.map(([title, hint]) => (
                  <article class="rounded-[28px] border border-[#162741]/10 bg-white p-5 shadow-[0_18px_60px_rgba(22,39,65,0.06)]">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#9a8954]">Canvas</p>
                    <h2 class="mt-2 text-sm font-extrabold leading-6 text-[#162741]">{title}</h2>
                    <p class="mt-1 text-xs leading-6 text-[#52657e]">{hint}</p>
                    <textarea data-canvas-field={title} class="mt-3 h-28 w-full rounded-2xl border border-[#162741]/10 bg-[#fbfbfc] px-3 py-3 text-sm outline-none transition focus:border-[#162741]" placeholder={`Escribe aquí: ${title}`}></textarea>
                  </article>
                ))}
              </div>
            </div>

            <aside class="rounded-4xl border border-[#162741]/10 bg-white p-7 shadow-[0_24px_80px_rgba(22,39,65,0.08)] md:p-8 lg:sticky lg:top-28">
              <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">Centro de mando</p>
              <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Diagnóstico del canvas</h2>
              <p class="mt-3 text-sm leading-7 text-[#52657e]">Entre más bloques llenes con claridad, más accionable se vuelve tu modelo.</p>
              <div id="canvas-diagnostico" class="mt-5 rounded-2xl border border-[#162741]/8 bg-[#162741]/2.5 p-4 text-sm leading-7 text-[#334865]">
                Completa varios bloques y luego pulsa “Generar diagnóstico”.
              </div>
              <div class="mt-5 space-y-3">
                <button id="btn-diagnostico-canvas" type="button" class="inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Generar diagnóstico</button>
                <button id="btn-descargar-canvas" type="button" class="inline-flex min-h-[52px] w-full items-center justify-center rounded-full border border-[#162741]/12 bg-white px-5 text-sm font-bold uppercase tracking-[0.14em] text-[#162741] transition hover:bg-[#162741]/2.5">Descargar borrador</button>
                <p class="text-xs text-[#667085]">
  Al continuar, aceptas nuestros
  <a href="/terminos" class="underline">Términos y Condiciones</a>
  y nuestra
  <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.
</p>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const fields = Array.from(document.querySelectorAll("[data-canvas-field]"));
      const diagnosis = document.getElementById("canvas-diagnostico");
      const btnDiag = document.getElementById("btn-diagnostico-canvas");
      const btnDownload = document.getElementById("btn-descargar-canvas");

      const buildReport = () => {
        const filled = fields.filter((field) => field.value.trim().length > 0);
        const count = filled.length;
        if (!diagnosis) return;
        if (count <= 2) {
          diagnosis.textContent = "Tu modelo todavía está muy verde. Empieza por cliente, propuesta de valor e ingresos.";
        } else if (count <= 5) {
          diagnosis.textContent = "Vas armando estructura. Ya puedes detectar vacíos, pero aún faltan piezas para validar si el modelo se sostiene.";
        } else if (count <= 8) {
          diagnosis.textContent = "Buen avance. Ya tienes un mapa accionable y puedes llevarlo a conversaciones con clientes o aliados.";
        } else {
          diagnosis.textContent = "Canvas bastante completo. El siguiente paso es contrastarlo con mercado real y convertirlo en experimentos concretos.";
        }
      };

      btnDiag?.addEventListener("click", buildReport);
      btnDownload?.addEventListener("click", () => {
        const lines = fields.map((field) => `## ${field.dataset.canvasField}\n${field.value.trim() || "(vacío)"}`);
        const blob = new Blob([lines.join("\n\n")], { type: "text/plain;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = "canvas-modelo-negocio.txt";
        link.click();
        URL.revokeObjectURL(url);
      });
    });
  </script>
</BaseLayout>
