---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Guía de Pitch para Inversores | Liga Emprendedora";
const pageDescription = "Estructura tu pitch para inversores con una guía clara y accionable.";
const quickRules = [
  "Empieza por el problema, no por tu ego.",
  "Usa una sola idea fuerte por slide.",
  "Muestra números reales, aunque sean pequeños.",
  "Cierra con una ronda clara: cuánto, para qué y qué hitos.",
];
const pitch3 = [
  ["0:00–0:20", "Quién eres, qué haces y para quién."],
  ["0:20–0:50", "Problema con un dato concreto que muestre urgencia."],
  ["0:50–1:20", "Solución y por qué es mejor que las alternativas."],
  ["1:20–1:50", "Tracción: clientes, uso, ventas o validación."],
  ["1:50–2:20", "Mercado y por qué esta oportunidad existe ahora."],
  ["2:20–3:00", "Ventaja, equipo y la ronda que estás levantando."],
];
const pitch5 = [
  ["0:00–0:30", "Apertura + resumen del problema."],
  ["0:30–1:20", "Solución, demo o ejemplo de uso."],
  ["1:20–2:00", "Modelo de negocio y cómo entra el dinero."],
  ["2:00–2:45", "Mercado, competencia y diferenciación."],
  ["2:45–3:45", "Tracción, métricas y aprendizajes."],
  ["3:45–5:00", "Equipo, uso de fondos y cierre."],
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />
    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(225,200,117,0.18),transparent_28%),radial-gradient(circle_at_top_right,rgba(224,244,89,0.10),transparent_20%)]"></div>
          <div class="absolute right-10 top-8 h-56 w-56 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>
        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">Recursos · Storytelling de capital</p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">No necesitas sonar grande. Necesitas sonar claro.</h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">Esta guía te ayuda a estructurar un pitch de 3 y 5 minutos para que un inversor entienda rápido el problema, la oportunidad, tu tracción y por qué vale la pena seguir la conversación.</p>
          </div>
          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">Reglas rápidas</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">{quickRules.map((item) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-[#e0f459]"></span><span>{item}</span></li>)}</ul>
            <a href="/#pitazo-final" class="mt-6 inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] transition hover:-translate-y-px">Quiero lanzar mi MVP</a>
          </aside>
        </div>
      </section>

      <section class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto max-w-7xl space-y-8">
          <div class="grid gap-8 lg:grid-cols-2">
            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">Formato corto</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Pitch de 3 minutos</h2>
              <div class="mt-6 space-y-4">
                {pitch3.map(([time, text]) => (
                  <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/[0.025] p-4">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#9a8954]">{time}</p>
                    <p class="mt-2 text-sm leading-7 text-[#334865]">{text}</p>
                  </div>
                ))}
              </div>
            </article>

            <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
              <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">Formato extendido</p>
              <h2 class="mt-2 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Pitch de 5 minutos</h2>
              <div class="mt-6 space-y-4">
                {pitch5.map(([time, text]) => (
                  <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/[0.025] p-4">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#9a8954]">{time}</p>
                    <p class="mt-2 text-sm leading-7 text-[#334865]">{text}</p>
                  </div>
                ))}
              </div>
            </article>
          </div>

          <article class="rounded-[30px] border border-[#162741]/10 bg-white p-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
            <h2 class="text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">Errores que matan un pitch</h2>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
              <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/[0.025] p-4"><p class="text-sm leading-7 text-[#334865]">Empezar contando la historia completa de la empresa sin dejar claro el problema.</p></div>
              <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/[0.025] p-4"><p class="text-sm leading-7 text-[#334865]">Llenar slides de texto y esconder la métrica principal.</p></div>
              <div class="rounded-2xl border border-[#162741]/8 bg-[#162741]/[0.025] p-4"><p class="text-sm leading-7 text-[#334865]">Pedir capital sin decir exactamente qué hitos vas a destrabar.</p></div>
            </div>
          </article>
        </div>
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
