---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type NewsletterEntry = CollectionEntry<"newsletter">;

const posts = (await getCollection("newsletter"))
  .slice()
  .sort((a, b) =>
    a.data.date && b.data.date && a.data.date < b.data.date ? 1 : -1
  );

const getImageSrc = (image: unknown) => {
  if (!image) return undefined;
  if (typeof image === "string") return image;
  if (typeof image === "object" && image !== null && "src" in image) {
    return (image as { src?: string }).src;
  }
  return undefined;
};
---

<BaseLayout
  title="Newsletter | Liga Emprendedora"
  description="Ideas tácticas, negocio, ejecución y herramientas para emprender con cabeza fría y mentalidad de cancha."
>
  <div class="flex min-h-screen flex-col bg-[#f4f6fa]">
    <Header dark />

    <main class="flex-1">
      <section class="bg-[#162741] px-4 py-16 text-white md:px-6 md:py-20">
        <div class="mx-auto max-w-6xl">
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">
            Newsletter
          </p>
          <h1 class="mt-4 max-w-3xl text-4xl font-extrabold leading-[0.96] tracking-[-0.04em] sm:text-5xl md:text-6xl">
            Ideas de juego para emprender con más táctica y menos humo.
          </h1>
          <p class="mt-6 max-w-2xl text-base leading-8 text-white/72 md:text-lg">
            Lecturas cortas sobre ejecución, negocio, validación, comunidad y mentalidad
            emprendedora.
          </p>
        </div>
      </section>

      <section class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post: NewsletterEntry) => {
            const imageSrc = getImageSrc(post.data.image);

            return (
              <article class="overflow-hidden rounded-4xl border border-[#162741]/8 bg-white shadow-[0_16px_40px_rgba(22,39,65,0.06)]">
                {imageSrc && (
                  <a href={`/newsletter/${post.slug}`}>
                    <img
                      src={imageSrc}
                      alt={post.data.title ?? "Imagen del artículo"}
                      class="h-56 w-full object-cover"
                      loading="lazy"
                    />
                  </a>
                )}

                <div class="p-6">
                  {post.data.category && (
                    <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">
                      {post.data.category}
                    </p>
                  )}

                  <h2 class="mt-3 text-2xl font-extrabold leading-tight tracking-[-0.03em] text-[#162741]">
                    <a href={`/newsletter/${post.slug}`} class="hover:opacity-80">
                      {post.data.title}
                    </a>
                  </h2>

                  {post.data.description && (
                    <p class="mt-4 text-sm leading-7 text-[#42556f]">
                      {post.data.description}
                    </p>
                  )}

                  <div class="mt-6">
                    <a
                      href={`/newsletter/${post.slug}`}
                      class="inline-flex items-center justify-center rounded-full bg-[#e0f459] px-5 py-3 text-sm font-semibold text-[#162741] transition hover:-translate-y-px"
                    >
                      Leer artículo
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>