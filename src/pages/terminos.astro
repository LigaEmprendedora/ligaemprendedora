---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const summaryCards = [
  {
    title: "Productos digitales",
    text: "Se entregan de forma inmediata una vez se confirme el pago. Recibirás por correo electrónico los accesos, credenciales o enlaces correspondientes.",
  },
  {
    title: "Productos físicos",
    text: "Aplican solo para envíos dentro de Colombia. El tiempo estimado de entrega es de 3 a 8 días hábiles, dependiendo de la ciudad y del operador logístico.",
  },
  {
    title: "Mentorías y sesiones",
    text: "Las sesiones del Pack DT se agendan según disponibilidad dentro de los 30 días posteriores a la compra y su prestación es virtual.",
  },
  {
    title: "Devoluciones",
    text: "Los productos digitales cuentan con garantía de satisfacción de 7 días calendario. Los productos físicos aplican para cambios o reposiciones por defectos o daños reportados a tiempo.",
  },
];

const termsBlocks = [
  {
    title: "1. Aceptación de las reglas del juego",
    text: [
      "Al adquirir el libro Emprende Futbolero, el acceso a El Búnker o cualquier producto de Liga Emprendedora, aceptas estos Términos y Condiciones.",
      "Si no estás de acuerdo con estas reglas, por favor no realices la compra.",
    ],
  },
  {
    title: "2. Promesa de valor y exención de responsabilidad",
    text: [
      "Emprende Futbolero y el método CANCHA son herramientas de estructuración, estrategia y alta gerencia. Entregamos tácticas, plantillas y conocimiento basado en experiencia real.",
      "Sin embargo, no garantizamos resultados financieros, comerciales ni de facturación. Tus resultados dependen de tu disciplina, tu ejecución y las condiciones del mercado. Nosotros te damos el mapa; tú decides cómo jugar el partido.",
    ],
    highlight: true,
  },
  {
    title: "3. Logística y entregas",
    sections: [
      {
        subtitle: "3.1 Productos digitales",
        text: [
          "Los productos digitales, incluyendo el Pack Canterano y los accesos digitales incluidos en otros packs, se entregan de forma inmediata una vez se confirme el pago.",
          "Recibirás por correo electrónico los accesos, credenciales o enlaces correspondientes.",
        ],
      },
      {
        subtitle: "3.2 Productos físicos",
        text: [
          "Los productos físicos, incluyendo el Pack Capitán y el Pack DT, tienen envío exclusivo dentro de Colombia.",
          "Los tiempos estimados de entrega son de 3 a 8 días hábiles, dependiendo de la ciudad y del operador logístico.",
          "Si una compra de producto físico se realiza con dirección de envío internacional, Liga Emprendedora podrá cancelar la orden o adaptar la compra a una versión digital equivalente.",
        ],
      },
      {
        subtitle: "3.3 Mentorías y sesiones",
        text: [
          "Las sesiones 1:1 y grupales incluidas en el Pack DT se agendarán según disponibilidad de agenda dentro de los 30 días posteriores a la compra.",
          "El acceso a estas sesiones es virtual y puede prestarse a clientes en cualquier país.",
        ],
      },
    ],
  },
  {
    title: "4. Política de devoluciones y garantía",
    sections: [
      {
        subtitle: "4.1 Productos digitales",
        text: [
          "Ofrecemos una garantía de satisfacción de 7 días calendario contados desde la fecha de compra.",
          "Si accedes a El Búnker, revisas el contenido y consideras que no te aporta valor, podrás solicitar la devolución dentro de ese plazo.",
        ],
      },
      {
        subtitle: "4.2 Productos físicos",
        text: [
          "Los productos físicos solo aplican para cambios o reposiciones en caso de defectos de impresión o daños atribuibles al transporte, siempre que sean reportados dentro de los 5 días calendario siguientes a la recepción.",
        ],
      },
    ],
  },
  {
    title: "5. Propiedad intelectual",
    text: [
      "Todo el contenido de Liga Emprendedora, incluyendo textos, plantillas, materiales descargables, videos, metodologías, marca, identidad visual y recursos de El Búnker o El Pizarrón, es propiedad exclusiva de Oswaldo Vega o de sus titulares autorizados.",
      "La compra otorga únicamente una licencia de uso personal e individual.",
    ],
    items: [
      "Revender.",
      "Copiar.",
      "Distribuir.",
      "Sublicenciar.",
      "Compartir con terceros.",
      "Usar el contenido con fines comerciales ajenos al propio emprendimiento del comprador.",
    ],
    closing:
      "En caso de uso indebido, piratería o distribución no autorizada, Liga Emprendedora podrá suspender el acceso y ejercer las acciones legales correspondientes.",
  },
];
---

<BaseLayout
  title="Términos y Condiciones | Liga Emprendedora"
  description="Reglas, condiciones de compra, entregas, devoluciones y uso de los contenidos de Liga Emprendedora."
>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-16 pt-20 text-white md:px-6 md:pb-20 md:pt-28">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(225,200,117,0.12),transparent_24%),linear-gradient(180deg,rgba(255,255,255,0.04)_0%,rgba(22,39,65,0)_42%)]"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto max-w-5xl">
          <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">
            Legal · Liga Emprendedora
          </p>

          <h1 class="mt-4 max-w-4xl text-4xl font-extrabold leading-[0.96] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">
            Términos y Condiciones
          </h1>

          <p class="mt-6 max-w-3xl text-base leading-8 text-white/74 md:text-[1.08rem] md:leading-9">
            Estas son las reglas del juego para el uso, compra y acceso a los productos,
            contenidos y servicios de Liga Emprendedora.
          </p>
        </div>
      </section>

      <section class="px-4 py-10 md:px-6 md:py-14">
        <div class="mx-auto max-w-5xl space-y-6">
          <div class="rounded-4xl border border-[#162741]/10 bg-white p-6 shadow-[0_18px_60px_rgba(22,39,65,0.06)] md:p-8">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
              Resumen rápido
            </p>
            <p class="mt-4 max-w-4xl text-base leading-8 text-[#334865] md:text-[1.05rem]">
              Al comprar en Liga Emprendedora aceptas las condiciones de uso, entrega,
              devoluciones y propiedad intelectual de nuestros productos. Te damos acceso
              a herramientas, contenidos y acompañamiento, pero los resultados dependen de tu ejecución.
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            {summaryCards.map((card) => (
              <article class="rounded-[30px] border border-[#162741]/10 bg-white p-6 shadow-[0_16px_50px_rgba(22,39,65,0.05)] md:p-7">
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[#9a8954]">
                  Términos
                </p>
                <h2 class="mt-3 text-2xl font-extrabold leading-tight tracking-[-0.03em] text-[#162741]">
                  {card.title}
                </h2>
                <p class="mt-4 text-sm leading-8 text-[#425674] md:text-[15px]">
                  {card.text}
                </p>
              </article>
            ))}
          </div>

          <div class="space-y-6">
            {termsBlocks.map((block) => (
              <article class={`rounded-[30px] border p-6 shadow-[0_16px_50px_rgba(22,39,65,0.05)] md:p-7 ${block.highlight ? "border-[#E1C875]/30 bg-[#162741] text-white" : "border-[#162741]/10 bg-white text-[#162741]"}`}>
                <p class={`text-[11px] font-semibold uppercase tracking-[0.2em] ${block.highlight ? "text-[#E1C875]" : "text-[#9a8954]"}`}>
                  Reglas del juego
                </p>

                <h2 class={`mt-3 text-2xl font-extrabold leading-tight tracking-[-0.03em] ${block.highlight ? "text-white" : "text-[#162741]"}`}>
                  {block.title}
                </h2>

                {block.text && (
                  <div class="mt-4 space-y-4">
                    {block.text.map((paragraph) => (
                      <p class={`text-sm leading-8 md:text-[15px] ${block.highlight ? "text-white/82" : "text-[#425674]"}`}>
                        {paragraph}
                      </p>
                    ))}
                  </div>
                )}

                {block.sections && (
                  <div class="mt-6 space-y-6">
                    {block.sections.map((section) => (
                      <div class={`rounded-2xl border p-5 ${block.highlight ? "border-white/10 bg-white/5" : "border-[#162741]/8 bg-[#f8fafc]"}`}>
                        <h3 class={`text-lg font-extrabold tracking-[-0.02em] ${block.highlight ? "text-white" : "text-[#162741]"}`}>
                          {section.subtitle}
                        </h3>
                        <div class="mt-3 space-y-3">
                          {section.text.map((paragraph) => (
                            <p class={`text-sm leading-8 md:text-[15px] ${block.highlight ? "text-white/80" : "text-[#425674]"}`}>
                              {paragraph}
                            </p>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                {block.items && (
                  <div class="mt-5">
                    <p class={`text-sm leading-8 md:text-[15px] ${block.highlight ? "text-white/82" : "text-[#425674]"}`}>
                      Queda estrictamente prohibido:
                    </p>

                    <ul class={`mt-4 space-y-3 text-sm leading-7 md:text-[15px] ${block.highlight ? "text-white/82" : "text-[#425674]"}`}>
                      {block.items.map((item) => (
                        <li class="flex items-start gap-3">
                          <span class={`mt-2 h-2 w-2 shrink-0 rounded-full ${block.highlight ? "bg-[#e0f459]" : "bg-[#9a8954]"}`}></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {block.closing && (
                  <p class={`mt-5 text-sm leading-8 md:text-[15px] ${block.highlight ? "text-white/82" : "text-[#425674]"}`}>
                    {block.closing}
                  </p>
                )}
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>