---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type LessonType = "leccion" | "powerplay" | "especial" | "bono";

type Lesson = {
  type: LessonType;
  label: string;
  title: string;
  plantilla: string;
  href: string;
};

type Period = {
  id: string;
  eyebrow: string;
  title: string;
  lessons: Lesson[];
};

const periods: Period[] = [
  {
    id: "pretemporada",
    eyebrow: "Pretemporada",
    title: "Identidad y primer silbatazo",
    lessons: [
      {
        type: "leccion",
        label: "Lección 1",
        title: "Estar preparado para hacer el cambio",
        plantilla: "El escáner del DT · Análisis DOFA + Gap Analysis",
        href: "/bunker/leccion-1",
      },
    ],
  },
  {
    id: "primer-tiempo",
    eyebrow: "Primer tiempo",
    title: "Descubrir el juego",
    lessons: [
      {
        type: "leccion",
        label: "Lección 2",
        title: "Sin actitud ganadora",
        plantilla: "El choque · Modelo GROW",
        href: "/bunker/leccion-2",
      },
      {
        type: "leccion",
        label: "Lección 3",
        title: "Me sentí campeón antes de tiempo",
        plantilla: "El filtro de la cantera · Validación de ideas",
        href: "/bunker/leccion-3",
      },
      {
        type: "powerplay",
        label: "Power-play CANCHA #1",
        title: "De la emoción a los números",
        plantilla: "Auditoría de cimentación · Costos + Audiencia",
        href: "/bunker/powerplay-1",
      },
      {
        type: "leccion",
        label: "Lección 4",
        title: "Mi cabeza en otro lado",
        plantilla: "La matriz de la cancha · Prioridades de Eisenhower",
        href: "/bunker/leccion-4",
      },
      {
        type: "leccion",
        label: "Lección 5",
        title: "Me ganó el miedo",
        plantilla: "El manual de jugadas · Procedimientos Operativos Estándar",
        href: "/bunker/leccion-5",
      },
    ],
  },
  {
    id: "medio-tiempo",
    eyebrow: "Medio tiempo",
    title: "Charla técnica",
    lessons: [
      {
        type: "especial",
        label: "Lección especial",
        title: "El salto – Vencer mis creencias a 3000 m",
        plantilla: "El túnel de salida · Vencer creencias limitantes",
        href: "/bunker/leccion-especial-salto",
      },
    ],
  },
  {
    id: "segundo-tiempo",
    eyebrow: "Segundo tiempo",
    title: "Aprender a definir",
    lessons: [
      {
        type: "leccion",
        label: "Lección 6",
        title: "No definí",
        plantilla: "Cobrar el penalti · Objetivos SMART",
        href: "/bunker/leccion-6",
      },
      {
        type: "leccion",
        label: "Lección 7",
        title: "Vivir de estadísticas",
        plantilla: "El pase filtrado · Bootstrapping y Triangulación",
        href: "/bunker/leccion-7",
      },
      {
        type: "leccion",
        label: "Lección 8",
        title: "No luché hasta el final",
        plantilla: "El pacto de camerino · Definición de OKRs",
        href: "/bunker/leccion-8",
      },
      {
        type: "powerplay",
        label: "Power-play CANCHA #2",
        title: "El alma del equipo",
        plantilla: "Auditoría de identidad · Narrativa + Cultura",
        href: "/bunker/powerplay-2",
      },
      {
        type: "leccion",
        label: "Lección 9",
        title: "Escuchar al público equivocado",
        plantilla: "El filtro de la tribuna · Validación de audiencia",
        href: "/bunker/leccion-9",
      },
    ],
  },
  {
    id: "tiempo-extra",
    eyebrow: "Tiempo extra",
    title: "Estrategia y crecimiento",
    lessons: [
      {
        type: "leccion",
        label: "Lección 10",
        title: "Jugar solo",
        plantilla: "La alineación táctica · Matriz RACI",
        href: "/bunker/leccion-10",
      },
      {
        type: "powerplay",
        label: "Power-play CANCHA #3",
        title: "El pitazo final",
        plantilla: "Plan de ataque inmediato · Habilidades + Acción",
        href: "/bunker/powerplay-3",
      },
      {
        type: "leccion",
        label: "Lección 11",
        title: "Subestimar al rival",
        plantilla: "El radar de scouting · Análisis de competidores",
        href: "/bunker/leccion-11",
      },
      {
        type: "especial",
        label: "Lección especial",
        title: "Jugué sin conocer las reglas",
        plantilla: "El draft de refuerzos · Contratación y delegación",
        href: "/bunker/leccion-especial-reglas",
      },
      {
        type: "especial",
        label: "Lección especial",
        title: "Soluciones creativas en momentos clave",
        plantilla: "El trueque estratégico · Financiación con presupuesto cero",
        href: "/bunker/leccion-especial-soluciones",
      },
    ],
  },
  {
    id: "ultimo-minuto",
    eyebrow: "Último minuto",
    title: "El próximo partido",
    lessons: [
      {
        type: "especial",
        label: "Lección especial · Bonus",
        title: "Un mentor invisible",
        plantilla: "La junta directiva invisible · Auditoría de mentores",
        href: "/bunker/leccion-especial-mentor",
      },
    ],
  },
];
---

<BaseLayout
  title="El Búnker | Liga Emprendedora"
  description="Todas las lecciones del Búnker organizadas por tiempos de partido. Plantillas, frameworks y jugadas tácticas para emprendedores."
>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <!-- HERO -->
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-16 pt-32 text-white md:px-6 md:pb-24 md:pt-36 lg:pt-40">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_14%_18%,rgba(224,244,89,0.10),transparent_24%),radial-gradient(circle_at_82%_20%,rgba(225,200,117,0.14),transparent_18%),linear-gradient(180deg,rgba(255,255,255,0.04)_0%,rgba(22,39,65,0)_44%)]"></div>
          <div class="absolute -left-10 top-12 h-44 w-44 rounded-full bg-white/6 blur-3xl"></div>
          <div class="absolute right-0 top-14 h-72 w-72 rounded-full bg-[#e0f459]/10 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto grid max-w-7xl items-end gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:gap-14">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-[#E1C875] md:text-xs">
              El Búnker · Programa completo
            </p>

            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.05em] text-white sm:text-5xl md:text-6xl lg:text-[4.4rem]">
              Cada lección. Cada jugada. Organizada por tiempo de partido.
            </h1>

            <p class="mt-7 max-w-2xl text-base leading-8 text-white/76 md:text-[1.15rem] md:leading-9">
              Desde la pretemporada hasta el último minuto: las lecciones, plantillas y power-plays que convierten errores reales en ventaja táctica.
            </p>

            <div class="mt-9 flex flex-wrap items-center gap-4">
              <button
                type="button"
                data-explore
                class="inline-flex items-center justify-center rounded-full bg-[#e0f459] px-7 py-3.5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_28px_rgba(224,244,89,0.16)] transition hover:-translate-y-px hover:shadow-[0_0_36px_rgba(224,244,89,0.26)]"
              >
                Ver todas las lecciones
              </button>

              <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/54 md:text-xs">
                6 tiempos · 17 lecciones
              </span>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
            <div class="rounded-[28px] border border-white/10 bg-white/7 p-5 backdrop-blur-sm">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#E1C875]">11 lecciones</p>
              <p class="mt-3 text-sm leading-7 text-white/78">Errores reales convertidos en plantillas accionables para no repetirlos en tu cancha.</p>
            </div>
            <div class="rounded-[28px] border border-white/10 bg-white/7 p-5 backdrop-blur-sm">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#E1C875]">3 Power-plays</p>
              <p class="mt-3 text-sm leading-7 text-white/78">Sesiones de trabajo intensivo para aterrizar números, identidad y plan de acción inmediato.</p>
            </div>
            <div class="rounded-[28px] border border-white/10 bg-white/7 p-5 backdrop-blur-sm">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#E1C875]">Bono VIP</p>
              <p class="mt-3 text-sm leading-7 text-white/78">Tu mapa de 90 días: el tablero táctico para ejecutar lo aprendido desde el primer día.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- LECCIONES POR TIEMPO -->
      <section id="lecciones" class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto max-w-4xl space-y-14">

          {periods.map((period) => (
            <div id={period.id}>
              <!-- Period heading -->
              <div class="mb-6 flex items-center gap-4">
                <div class="flex-1">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-[#9a8954]">
                    {period.eyebrow}
                  </p>
                  <h2 class="mt-1.5 text-2xl font-extrabold leading-tight tracking-[-0.04em] text-[#162741] md:text-3xl">
                    {period.title}
                  </h2>
                </div>
                <div class="h-px flex-1 bg-[#162741]/10"></div>
              </div>

              <!-- Lessons list -->
              <div class="space-y-3">
                {period.lessons.map((lesson) => (
                  <Fragment>
                    {lesson.type === "powerplay" && (
                      <a
                        href={lesson.href}
                        class="group flex items-center gap-5 rounded-3xl bg-[#162741] px-6 py-5 shadow-[0_12px_40px_rgba(22,39,65,0.14)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_20px_56px_rgba(22,39,65,0.20)] md:px-7"
                      >
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#e0f459] shadow-[0_0_20px_rgba(224,244,89,0.30)]">
                          <svg viewBox="0 0 24 24" class="h-5 w-5 text-[#162741]" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                          </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="text-[10px] font-semibold uppercase tracking-[0.28em] text-[#e0f459]">{lesson.label}</p>
                          <p class="mt-0.5 text-base font-extrabold leading-snug tracking-[-0.02em] text-white md:text-lg">{lesson.title}</p>
                          <p class="mt-1 text-[13px] text-white/56">{lesson.plantilla}</p>
                        </div>
                        <span class="ml-2 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/14 text-white/60 transition group-hover:border-[#e0f459]/60 group-hover:text-[#e0f459]">
                          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                        </span>
                      </a>
                    )}
                    {lesson.type === "especial" && (
                      <a
                        href={lesson.href}
                        class="group flex items-center gap-5 rounded-3xl border border-[#E1C875]/35 bg-[#E1C875]/8 px-6 py-5 transition duration-300 hover:-translate-y-0.5 hover:border-[#E1C875]/60 hover:bg-[#E1C875]/14 hover:shadow-[0_12px_40px_rgba(225,200,117,0.12)] md:px-7"
                      >
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#E1C875]/30 bg-white text-[#9a8954] shadow-sm">
                          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                          </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="text-[10px] font-semibold uppercase tracking-[0.28em] text-[#9a8954]">{lesson.label}</p>
                          <p class="mt-0.5 text-base font-extrabold leading-snug tracking-[-0.02em] text-[#162741] md:text-lg">{lesson.title}</p>
                          <p class="mt-1 text-[13px] text-[#4b5f78]">{lesson.plantilla}</p>
                        </div>
                        <span class="ml-2 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[#162741]/12 text-[#162741]/40 transition group-hover:border-[#9a8954]/50 group-hover:text-[#9a8954]">
                          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                        </span>
                      </a>
                    )}
                    {lesson.type === "leccion" && (
                      <a
                        href={lesson.href}
                        class="group flex items-center gap-5 rounded-3xl border border-[#162741]/10 bg-white px-6 py-5 shadow-[0_8px_28px_rgba(22,39,65,0.05)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_16px_48px_rgba(22,39,65,0.09)] md:px-7"
                      >
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#E1C875]/30 bg-[#162741] text-[#e0f459] shadow-[0_8px_20px_rgba(22,39,65,0.14)]">
                          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                            <polyline points="14 2 14 8 20 8" />
                          </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="text-[10px] font-semibold uppercase tracking-[0.28em] text-[#9a8954]">{lesson.label}</p>
                          <p class="mt-0.5 text-base font-extrabold leading-snug tracking-[-0.02em] text-[#162741] md:text-lg">{lesson.title}</p>
                          <p class="mt-1 text-[13px] text-[#4b5f78]">{lesson.plantilla}</p>
                        </div>
                        <span class="ml-2 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[#162741]/12 text-[#162741]/40 transition group-hover:border-[#162741]/30 group-hover:text-[#162741]">
                          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                        </span>
                      </a>
                    )}
                  </Fragment>
                ))}
              </div>
            </div>
          ))}

          <!-- BONO VIP -->
          <div id="bono-vip">
            <div class="mb-6 flex items-center gap-4">
              <div class="flex-1">
                <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-[#9a8954]">
                  Bono VIP
                </p>
                <h2 class="mt-1.5 text-2xl font-extrabold leading-tight tracking-[-0.04em] text-[#162741] md:text-3xl">
                  El tablero táctico
                </h2>
              </div>
              <div class="h-px flex-1 bg-[#162741]/10"></div>
            </div>

            <a
              href="/bunker/bono-vip"
              class="group relative flex items-center gap-6 overflow-hidden rounded-[28px] bg-[#162741] px-7 py-7 shadow-[0_20px_60px_rgba(22,39,65,0.18)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_28px_80px_rgba(22,39,65,0.24)]"
            >
              <!-- Background glow -->
              <div class="pointer-events-none absolute inset-0">
                <div class="absolute -right-8 -top-8 h-48 w-48 rounded-full bg-[#e0f459]/10 blur-3xl"></div>
                <div class="absolute -bottom-6 left-12 h-36 w-36 rounded-full bg-[#E1C875]/10 blur-2xl"></div>
              </div>

              <div class="relative flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-[#E1C875]/40 bg-linear-to-br from-[#E1C875] to-[#c9a94e] shadow-[0_0_32px_rgba(225,200,117,0.30)]">
                <svg viewBox="0 0 24 24" class="h-7 w-7 text-[#162741]" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7" />
                  <rect x="14" y="3" width="7" height="7" />
                  <rect x="14" y="14" width="7" height="7" />
                  <rect x="3" y="14" width="7" height="7" />
                </svg>
              </div>

              <div class="relative min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-[#E1C875]">
                    Acceso exclusivo
                  </p>
                  <span class="rounded-full border border-[#E1C875]/30 bg-[#E1C875]/12 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-[#E1C875]">
                    VIP
                  </span>
                </div>
                <p class="mt-1.5 text-lg font-extrabold leading-snug tracking-[-0.02em] text-white md:text-xl">
                  Tu Mapa de 90 días
                </p>
                <p class="mt-1.5 text-[13px] leading-relaxed text-white/60">
                  El tablero táctico para ejecutar todo lo aprendido desde el primer día. Convierte las lecciones en acciones concretas con fechas y métricas.
                </p>
              </div>

              <span class="relative ml-2 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#E1C875]/30 text-[#E1C875] transition group-hover:border-[#E1C875] group-hover:bg-[#E1C875]/12">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          </div>

        </div>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const exploreBtn = document.querySelector("[data-explore]");
      const leccionesSection = document.getElementById("lecciones");

      if (exploreBtn && leccionesSection) {
        exploreBtn.addEventListener("click", () => {
          leccionesSection.scrollIntoView({ behavior: "smooth" });
        });
      }
    });
  </script>
</BaseLayout>
