---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsletterLayout from '../../layouts/NewsletterLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type NewsletterEntry = CollectionEntry<'newsletter'>;

const getDateValue = (value?: Date | string) => {
  if (!value) return 0;
  return new Date(value).getTime();
};

const formatDate = (value?: Date | string) => {
  if (!value) return '';
  return new Date(value).toLocaleDateString('es-CO', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const getImageSrc = (image: unknown) => {
  if (!image) return undefined;
  if (typeof image === 'string') return image;
  if (typeof image === 'object' && image !== null && 'src' in image) {
    return (image as { src?: string }).src;
  }
  return undefined;
};

export async function getStaticPaths() {
  const posts = await getCollection('newsletter');

  return posts.map((post: NewsletterEntry) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post?: NewsletterEntry };

if (!post) {
  throw new Error('No se encontró el artículo del newsletter para esta ruta.');
}

const { Content } = await post.render();
const fm = post.data ?? {};
const coverImage = getImageSrc(fm.image);

const allPosts = await getCollection('newsletter');

const relatedPosts = (allPosts as NewsletterEntry[])
  .filter((item: NewsletterEntry) => item.slug !== post.slug)
  .sort((a: NewsletterEntry, b: NewsletterEntry) => getDateValue(b.data.date) - getDateValue(a.data.date))
  .slice(0, 4);

const latestPosts = (allPosts as NewsletterEntry[])
  .slice()
  .sort((a: NewsletterEntry, b: NewsletterEntry) => getDateValue(b.data.date) - getDateValue(a.data.date))
  .slice(0, 5);
---

<BaseLayout title={fm.title} description={fm.description}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-20 pt-28 text-white md:px-6 md:pb-28 md:pt-36 lg:pb-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_12%,rgba(225,200,117,0.14),transparent_20%),radial-gradient(circle_at_86%_18%,rgba(224,244,89,0.08),transparent_18%),linear-gradient(180deg,rgba(255,255,255,0.04)_0%,rgba(255,255,255,0)_26%),linear-gradient(180deg,#162741_0%,#102038_55%,#0d192c_100%)]"></div>
          <div class="absolute left-1/2 top-0 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-white/4 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto max-w-7xl">
          <a
            href="/newsletter"
            class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-white/66 transition hover:text-white"
          >
            <span aria-hidden="true">←</span>
            <span>Volver al Newsletter</span>
          </a>

          <div class="mt-8 grid gap-12 lg:grid-cols-[minmax(0,1.12fr)_minmax(320px,0.88fr)] lg:gap-16 xl:gap-20">
            <div class="max-w-4xl">
              <div class="flex flex-wrap items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.24em]">
                {fm.category && (
                  <span class="rounded-full border border-[#E1C875]/45 bg-[#E1C875]/10 px-3 py-1 text-[#E1C875]">
                    {fm.category}
                  </span>
                )}
                {fm.date && (
                  <span class="text-white/58 normal-case tracking-normal">
                    {formatDate(fm.date)}
                  </span>
                )}
              </div>

              <h1 class="mt-6 max-w-4xl text-4xl font-extrabold leading-[0.92] tracking-[-0.05em] text-white sm:text-5xl md:text-6xl lg:text-[4.65rem] xl:text-[5rem]">
                {fm.title}
              </h1>

              {fm.description && (
                <div class="mt-8 max-w-3xl rounded-[28px] border border-white/10 bg-white/6 px-6 py-6 shadow-[0_24px_70px_rgba(0,0,0,0.18)] backdrop-blur-sm md:px-7 md:py-7">
                  <p class="text-base leading-8 text-white/80 md:text-[1.12rem] md:leading-9">
                    {fm.description}
                  </p>
                </div>
              )}

              <div class="mt-10 flex flex-wrap items-center gap-4 md:gap-5">
                <a
                  href="/#pitazo-final"
                  class="inline-flex items-center justify-center rounded-full bg-[#e0f459] px-6 py-3 text-xs font-extrabold uppercase tracking-[0.16em] text-[#162741] shadow-[0_0_28px_rgba(224,244,89,0.18)] transition hover:-translate-y-px hover:shadow-[0_0_36px_rgba(224,244,89,0.28)]"
                >
                  Quiero lanzar mi MVP
                </a>
                <a
                  href="/newsletter"
                  class="inline-flex items-center justify-center rounded-full border border-white/14 px-6 py-3 text-xs font-bold uppercase tracking-[0.16em] text-white/82 transition hover:bg-white/6 hover:text-white"
                >
                  Ver más artículos
                </a>
              </div>
            </div>

            <div class="flex lg:justify-end">
              {coverImage ? (
                <div class="group relative w-full max-w-[34rem] overflow-hidden rounded-[34px] border border-white/10 bg-[#0f1b2f] shadow-[0_28px_100px_rgba(0,0,0,0.3)]">
                  <div class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(180deg,rgba(255,255,255,0.03)_0%,rgba(0,0,0,0.08)_100%)]"></div>
                  <img
                    src={coverImage}
                    alt={fm.title ?? 'Imagen del artículo'}
                    class="aspect-[1.02/1] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                  <div class="absolute inset-x-0 bottom-0 z-10 p-6">
                    <div class="inline-flex rounded-full border border-white/12 bg-[#162741]/70 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-white/78 backdrop-blur-sm">
                      Liga Emprendedora · Lectura táctica
                    </div>
                  </div>
                </div>
              ) : (
                <div class="w-full max-w-[34rem] rounded-[34px] border border-white/10 bg-[linear-gradient(180deg,#1e304f_0%,#101d31_100%)] p-8 shadow-[0_28px_100px_rgba(0,0,0,0.3)] md:p-10">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">
                    Nota táctica
                  </p>
                  <h2 class="mt-5 text-2xl font-extrabold leading-tight text-white md:text-3xl">
                    Una lectura pensada para dejarte menos teoría y más jugadas claras.
                  </h2>
                  <p class="mt-5 max-w-md text-sm leading-7 text-white/74 md:text-base md:leading-8">
                    Contexto útil, lenguaje simple y una sola obsesión: que cierres esta página con algo accionable para tu negocio.
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="px-4 py-16 md:px-6 md:py-20 lg:py-24">
        <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start lg:gap-16 xl:grid-cols-[minmax(0,1fr)_360px] xl:gap-20">
          <div class="min-w-0">
            <NewsletterLayout frontmatter={fm}>
              <Content />
            </NewsletterLayout>
          </div>

          <aside class="space-y-6 lg:sticky lg:top-28">
            <section class="rounded-[28px] border border-[#162741]/8 bg-white px-6 py-7 shadow-[0_18px_60px_rgba(22,39,65,0.06)]">
              <h2 class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
                Más de la Liga
              </h2>
              <div class="mt-6 space-y-5">
                {relatedPosts.map((item: NewsletterEntry) => (
                  <article class="border-b border-[#162741]/8 pb-5 last:border-b-0 last:pb-0">
                    <a
                      href={`/newsletter/${item.slug}`}
                      class="text-[15px] font-bold leading-7 text-[#162741] transition hover:text-[#a9872d]"
                    >
                      {item.data.title}
                    </a>
                    <div class="mt-2 flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.16em] text-[#6b7280]">
                      {item.data.category && <span>{item.data.category}</span>}
                      {item.data.date && <span>{formatDate(item.data.date)}</span>}
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section class="rounded-[28px] border border-[#E1C875]/18 bg-[#162741] px-6 py-7 text-white shadow-[0_22px_70px_rgba(22,39,65,0.12)]">
              <h2 class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#E1C875]">
                Lo más reciente
              </h2>
              <div class="mt-6 space-y-3">
                {latestPosts.map((item: NewsletterEntry) => (
                  <a
                    href={`/newsletter/${item.slug}`}
                    class="block rounded-[22px] border border-white/8 bg-white/4 px-4 py-4 text-sm leading-7 text-white/82 transition hover:border-[#E1C875]/30 hover:bg-white/7 hover:text-white"
                  >
                    {item.data.title}
                  </a>
                ))}
              </div>
            </section>
          </aside>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
