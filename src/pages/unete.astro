---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const benefits = [
  "Contenido útil y directo para emprendedores en LATAM.",
  "Retos semanales para dejar de pensar y empezar a ejecutar.",
  "Acceso anticipado a comunidad, recursos y dinámicas privadas.",
];

const trustPoints = [
  "Acceso gratuito",
  "Sin spam",
  "Contenido accionable",
  "Comunidad en crecimiento",
];
---

<BaseLayout
  title="Únete | Liga Emprendedora"
  description="Únete gratis a Liga Emprendedora: recibe contenido útil, accede a la Pretemporada 2026 y entra al vestuario donde entrenan emprendedores de LATAM."
>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-16 pt-28 text-white md:px-6 md:pb-24 md:pt-36">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(225,200,117,0.14),transparent_26%),radial-gradient(circle_at_78%_22%,rgba(224,244,89,0.12),transparent_18%),linear-gradient(180deg,rgba(255,255,255,0.03)_0%,rgba(22,39,65,0)_40%)]"></div>
          <div class="absolute right-[-60px] top-10 h-64 w-64 rounded-full bg-[#e0f459]/10 blur-3xl"></div>
          <div class="absolute left-[-40px] top-24 h-56 w-56 rounded-full bg-white/6 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(420px,0.95fr)] lg:items-center">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#E1C875] md:text-xs">
              Pretemporada 2026 · Cupos limitados
            </p>

            <h1 class="mt-5 text-4xl font-extrabold leading-[0.94] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl lg:text-[4.4rem]">
              Únete gratis a la Liga.
              <span class="block text-white/92">Empieza a jugar tu partido.</span>
            </h1>

            <p class="mt-7 max-w-2xl text-base leading-8 text-white/78 md:text-[1.12rem]">
              Entra al vestuario, recibe contenido útil, retos semanales, recursos y acceso anticipado
              al grupo privado de emprendedores en LATAM.
            </p>

            <div class="mt-9 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/76 backdrop-blur-sm md:text-xs">
              <span class="h-2 w-2 rounded-full bg-[#e0f459] shadow-[0_0_14px_rgba(224,244,89,0.5)]"></span>
              <span>Sin spam. Solo táctica útil para ejecutar.</span>
            </div>

            <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              {trustPoints.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
                  <p class="text-sm font-semibold text-white/90">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="relative">
            <div class="absolute inset-x-6 top-6 h-full rounded-[34px] bg-[radial-gradient(circle_at_center,rgba(224,244,89,0.16),transparent_60%)] blur-2xl"></div>
            <div class="relative rounded-[30px] border border-white/12 bg-white/96 p-6 text-[#162741] shadow-[0_28px_90px_rgba(3,10,24,0.28)] md:p-8">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
                    Acceso gratuito
                  </p>
                  <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741] md:text-[2rem]">
                    Inscríbete a la Pretemporada 2026
                  </h2>
                </div>
                <div class="rounded-2xl border border-[#162741]/10 bg-[#f6f5f2] px-3 py-2 text-[10px] font-bold uppercase tracking-[0.18em] text-[#162741]">
                  Gratis
                </div>
              </div>

              <p class="mt-4 text-sm leading-7 text-[#4f627b]">
                Déjanos tus datos y entra al vestuario donde se entrena con ideas, comunidad y ejecución real.
              </p>

              <form
                name="unete"
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                class="mt-7 space-y-5"
              >
                <input type="hidden" name="form-name" value="unete" />

                <p class="hidden">
                  <label>No llenar: <input name="bot-field" /></label>
                </p>

                <div class="grid gap-5 md:grid-cols-2">
                  <div class="md:col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.14em] text-[#55657d]">
                      Nombre completo*
                    </label>
                    <input
                      type="text"
                      name="nombre"
                      required
                      class="mt-2 w-full rounded-2xl border border-[#d8dde6] bg-white px-4 py-3 text-sm outline-none transition focus:border-[#162741] focus:ring-2 focus:ring-[#162741]/8"
                    />
                  </div>

                  <div class="md:col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.14em] text-[#55657d]">
                      Email*
                    </label>
                    <input
                      type="email"
                      name="email"
                      required
                      class="mt-2 w-full rounded-2xl border border-[#d8dde6] bg-white px-4 py-3 text-sm outline-none transition focus:border-[#162741] focus:ring-2 focus:ring-[#162741]/8"
                    />
                  </div>

                  <div class="md:col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.14em] text-[#55657d]">
                      País
                    </label>
                    <input
                      type="text"
                      name="pais"
                      class="mt-2 w-full rounded-2xl border border-[#d8dde6] bg-white px-4 py-3 text-sm outline-none transition focus:border-[#162741] focus:ring-2 focus:ring-[#162741]/8"
                    />
                  </div>

                  <div class="md:col-span-2">
                    <label class="block text-xs font-semibold uppercase tracking-[0.14em] text-[#55657d]">
                      ¿Qué estás emprendiendo?
                    </label>
                    <textarea
                      name="proyecto"
                      rows="4"
                      class="mt-2 w-full rounded-2xl border border-[#d8dde6] bg-white px-4 py-3 text-sm outline-none transition focus:border-[#162741] focus:ring-2 focus:ring-[#162741]/8"
                      placeholder="Idea o negocio actual"
                    ></textarea>
                  </div>
                </div>

                <button
                  type="submit"
                  class="mt-2 inline-flex min-h-[56px] w-full items-center justify-center rounded-full bg-[#e0f459] px-6 py-3 text-sm font-extrabold uppercase tracking-[0.16em] text-[#162741] shadow-[0_0_28px_rgba(224,244,89,0.2)] transition hover:-translate-y-px hover:shadow-[0_0_36px_rgba(224,244,89,0.3)] md:text-base"
                >
                  Unirme a la Liga
                </button>

                <p class="text-center text-[11px] leading-6 text-[#6b7280]">
                  Sin spam. Sin ruido. Solo contenido útil para emprendedores.
                </p>
              </form>
            </div>
          </div>
        </div>
      </section>

      <section class="px-4 py-14 md:px-6 md:py-20">
        <div class="mx-auto max-w-6xl">
          <div class="mx-auto max-w-3xl text-center">
            <p class="text-[11px] font-semibold uppercase tracking-[0.26em] text-[#9a8954] md:text-xs">
              Qué desbloqueas al entrar
            </p>
            <h2 class="mt-4 text-3xl font-extrabold leading-tight tracking-[-0.035em] text-[#162741] md:text-5xl">
              Aquí no hay banca. Todos juegan.
            </h2>
            <p class="mt-5 text-base leading-8 text-[#4f627b] md:text-[1.08rem]">
              Al unirte, recibes acceso al vestuario: ideas, herramientas, comunidad y
              contenido accionable para avanzar cada semana.
            </p>
          </div>

          <div class="mt-12 grid gap-5 md:grid-cols-3">
            {benefits.map((item, index) => (
              <div class="rounded-[26px] border border-[#162741]/10 bg-white p-6 shadow-[0_16px_50px_rgba(22,39,65,0.06)]">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#162741] text-sm font-extrabold text-[#e0f459]">
                  0{index + 1}
                </div>
                <p class="mt-5 text-base font-semibold leading-8 text-[#162741]">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
