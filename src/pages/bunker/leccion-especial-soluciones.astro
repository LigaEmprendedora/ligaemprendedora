---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "Lección Especial: El Trueque Estratégico | Liga Emprendedora";
const pageDescription =
  "Corporate Bartering y emparejamiento de valor. Financia tu MVP usando tu talento como moneda inagotable, sin necesidad de liquidez.";
const downloadLink = "https://drive.google.com/file/d/1v3bAba12uFFv8aBvQ2VYjoShBhTTDgU5/view?usp=sharing";



const bullets = [
  "Tu inventario oculto: el talento que tienes y que para otros tiene alto impacto comercial.",
  "El recurso exacto que necesitas sin desestabilizar tu flujo de caja.",
  "Los 3 candidatos reales con quienes puedes hacer el canje hoy mismo.",
  "El script de negociación listo para enviar y cerrar el trueque sin sonar quebrado.",
];


const signals = [
  { label: "Sección", value: "Tiempo Extra" },
  { label: "Herramienta", value: "Corporate Bartering" },
  { label: "Plantilla", value: "El Trueque Estratégico" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col bg-[#f6f5f2] text-[#162741]">
    <Header dark />

    <main class="flex-1">
      <section class="relative overflow-hidden bg-[#162741] px-4 pb-14 pt-28 text-white md:px-6 md:pb-20 md:pt-32">
        <div class="pointer-events-none absolute inset-0">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(224,244,89,0.14),transparent_28%),radial-gradient(circle_at_top_right,rgba(224,244,89,0.08),transparent_20%),linear-gradient(180deg,rgba(255,255,255,0.03)_0%,rgba(22,39,65,0)_42%)]"></div>
          <div class="absolute -left-10 top-10 h-52 w-52 rounded-full bg-white/5 blur-3xl"></div>
          <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-[#e0f459]/10 blur-3xl"></div>
          <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>
        </div>

        <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-end">
          <div class="max-w-3xl">
            <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#e0f459] md:text-xs">
              Búnker · Tiempo Extra
            </p>
            <h1 class="mt-5 text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white sm:text-5xl md:text-6xl">
El Trueque Estratégico
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-white/76 md:text-[1.08rem]">
             Corporate Bartering y Emparejamiento de Valor
            </p>

            <div class="mt-8 grid gap-3 sm:grid-cols-3">
              {signals.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 backdrop-blur-sm">
                  <p class="text-[10px] uppercase tracking-[0.2em] text-white/55">{item.label}</p>
                  <p class="mt-2 text-sm font-semibold text-white">{item.value}</p>
                </div>
              ))}
            </div>
          </div>

          <aside class="rounded-[30px] border border-white/12 bg-white/6 p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur-md">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#e0f459]">Qué desbloqueas</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-white/78">
              {bullets.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#e0f459]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href="#descarga-powerplay-1"
              class="mt-6 inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[#e0f459] px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_30px_rgba(224,244,89,0.18)] transition hover:-translate-y-px hover:shadow-[0_0_40px_rgba(224,244,89,0.28)]"
            >
              Quiero la plantilla
            </a>
          </aside>
        </div>
      </section>

      <section id="descarga-powerplay-1" class="px-4 py-12 md:px-6 md:py-16">
        <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,1.05fr)_420px]">
          <div>
            <article class="rounded-[30px] border border-[#162741] bg-[#162741] p-7 shadow-[0_18px_60px_rgba(22,39,65,0.14)] md:p-8">
              <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#e0f459]">
                 Instrucción del DT
              </p>
              <p class="mt-5 text-base leading-8 text-white/88 md:text-[1.08rem] md:leading-9">
La mentira más grande que frena a los emprendedores es decir "no tengo plata para arrancar". La falta de liquidez nunca es un muro de concreto; es solo un desvío táctico para obligarte a pensar diferente. Usa esta matriz para quitar el dinero de la ecuación, conectar necesidades y financiar tu proyecto usando tu talento como moneda inagotable.          </div>

          <aside class="rounded-4xl border border-[#162741]/10 bg-white p-7 shadow-[0_24px_80px_rgba(22,39,65,0.08)] md:p-8 lg:sticky lg:top-28">
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#9a8954]">
              Acceso inmediato
            </p>
            <h2 class="mt-3 text-2xl font-extrabold tracking-[-0.03em] text-[#162741]">
              Descarga gratis el Power-play #1
            </h2>
            <p class="mt-3 text-sm leading-7 text-[#52657e]">
              Déjanos tus datos y verás el enlace directo de descarga al instante.
            </p>

            <form
              class="mt-6 space-y-4"
              name="bunker-powerplay-1"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              data-download-link={downloadLink}
              data-resource-form
            >
              <input type="hidden" name="form-name" value="bunker-powerplay-1" />
              <p class="hidden"><label>No llenar: <input name="bot-field" /></label></p>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Nombre completo*</label>
                <input
                  type="text"
                  name="nombre"
                  required
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Email*</label>
                <input
                  type="email"
                  name="email"
                  required
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Nombre de la empresa</label>
                <input
                  type="text"
                  name="empresa"
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <div>
                <label class="block text-xs font-semibold text-[#4b5563]">Teléfono</label>
                <input
                  type="tel"
                  name="telefono"
                  class="mt-1.5 w-full rounded-2xl border border-[#d9dfeb] bg-[#fbfbfc] px-4 py-3 text-sm outline-none transition focus:border-[#162741]"
                />
              </div>

              <button
                type="submit"
                data-submit-btn
                class="relative inline-flex min-h-[54px] w-full items-center justify-center rounded-full bg-[#e0f459] px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-[#162741] shadow-[0_0_28px_rgba(224,244,89,0.18)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_0_40px_rgba(224,244,89,0.35)] hover:bg-[#d4e84f] active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed"
              >
                <span data-btn-text>Descargar recurso</span>
                <span data-btn-loading class="hidden absolute inset-0 items-center justify-center gap-2">
                  <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                  </svg>
                  Enviando...
                </span>
              </button>

              <p class="text-[11px] leading-5 text-[#6b7280]">
                Sin spam. Solo recursos, herramientas y tácticas de negocio de la Liga.
              </p>

              <p class="text-xs text-[#667085]">
                Al continuar, aceptas nuestros
                <a href="/terminos" class="underline">Términos y Condiciones</a>
                y nuestra
                <a href="/politica-privacidad" class="underline">Política de Privacidad</a>.
              </p>

              <div class="hidden rounded-2xl bg-[#ecfdf3] border border-[#86efac] px-5 py-5 text-sm text-[#14532d]" data-download-message>
                <p class="font-extrabold text-base text-[#14532d] mb-2">¡Listo, está en la cancha! 🎯</p>
                <p class="mb-4 text-[#166534]">Tu plantilla está lista para descargar.</p>
                <a href="#" target="_blank" data-download-href class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#162741] px-5 py-3.5 text-sm font-extrabold uppercase tracking-[0.14em] text-white shadow-[0_0_24px_rgba(22,39,65,0.18)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_0_32px_rgba(22,39,65,0.28)]">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                  Descargar ahora
                </a>
              </div>
            </form>
          </aside>
        </div>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline>
    document.querySelectorAll('[data-resource-form]').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn = form.querySelector('[data-submit-btn]');
        const text = form.querySelector('[data-btn-text]');
        const loading = form.querySelector('[data-btn-loading]');
        const message = form.querySelector('[data-download-message]');
        const downloadHref = form.querySelector('[data-download-href]');
        const link = form.getAttribute('data-download-link');
        if (btn && text && loading) {
          btn.disabled = true;
          text.classList.add('hidden');
          loading.classList.remove('hidden');
        }
        setTimeout(() => {
          if (loading) loading.classList.add('hidden');
          if (btn) btn.classList.add('hidden');
          if (message) message.classList.remove('hidden');
          if (downloadHref && link) downloadHref.setAttribute('href', link);
        }, 1500);
      });
    });
  </script>
</BaseLayout>