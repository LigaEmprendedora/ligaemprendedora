---
interface Frontmatter {
  title?: string;
  description?: string;
  date?: string | Date;
  category?: string;
  image?: string | { src?: string };
}

interface Props {
  frontmatter?: Frontmatter;
  fm?: Frontmatter;
  post?: { data?: Frontmatter };
}

const rawFrontmatter = Astro.props.frontmatter ?? Astro.props.fm ?? Astro.props.post?.data ?? {};
const frontmatter: Frontmatter = rawFrontmatter ?? {};

const imageSrc =
  typeof frontmatter.image === 'string'
    ? frontmatter.image
    : frontmatter.image?.src;

const imageAlt = frontmatter.title ?? 'Imagen del artículo';
---

<div class="min-w-0">
  {imageSrc && (
    <div class="overflow-hidden rounded-[30px] border border-[#162741]/10 bg-white p-2 shadow-[0_20px_70px_rgba(22,39,65,0.08)]">
      <img
        src={imageSrc}
        alt={imageAlt}
        class="h-[260px] w-full rounded-[24px] object-cover md:h-[420px]"
        loading="lazy"
      />
    </div>
  )}

  <article
    class="newsletter-article prose prose-sm mt-10 max-w-none rounded-[30px] border border-[#162741]/10 bg-white px-6 py-9 shadow-[0_20px_70px_rgba(22,39,65,0.06)] md:prose-base md:mt-12 md:px-10 md:py-12
           prose-headings:font-extrabold prose-headings:tracking-[-0.03em]
           prose-h2:text-[#162741] prose-h3:text-[#162741] prose-h4:text-[#162741]
           prose-h2:mt-12 prose-h2:mb-5 prose-h3:mt-10 prose-h3:mb-4 prose-h4:mt-8 prose-h4:mb-3
           prose-p:text-[#334865] prose-p:leading-8 prose-p:my-6 md:prose-p:my-7
           prose-strong:text-[#162741]
           prose-a:text-[#a9872d] hover:prose-a:text-[#8b6f24]
           prose-ul:my-8 prose-ol:my-8 prose-li:text-[#334865] prose-li:leading-8 prose-li:my-2 prose-li:marker:text-[#E1C875]
           prose-blockquote:my-10 prose-blockquote:border-l-[#E1C875] prose-blockquote:text-[#162741]
           prose-hr:my-12 prose-hr:border-[#162741]/10
           prose-img:my-10 prose-img:rounded-[22px]"
  >
    <slot />
  </article>
</div>

<style>
  .newsletter-article :global(p) {
    margin-top: 1.35rem;
    margin-bottom: 1.35rem;
  }

  .newsletter-article :global(.sources-title) {
    padding-top: 1.5rem;
    margin-top: 2.5rem;
    font-size: 0.78rem;
    line-height: 1.2rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8b95a7;
    font-style: italic;
  }

  .newsletter-article :global(.source-item) {
    margin-top: 1.1rem;
    margin-bottom: 1.1rem;
    color: #667085;
    font-style: italic;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const articles = document.querySelectorAll('.newsletter-article');

    articles.forEach((article) => {
      const paragraphs = Array.from(article.querySelectorAll('p'));
      let inSourcesBlock = false;

      paragraphs.forEach((p) => {
        const text = (p.textContent || '').trim().toLowerCase();
        const onlyItalic = p.children.length === 1 && p.firstElementChild?.tagName === 'EM';

        if (text === 'fuentes' && onlyItalic) {
          p.classList.add('sources-title');
          inSourcesBlock = true;
          return;
        }

        if (inSourcesBlock && onlyItalic) {
          p.classList.add('source-item');
          return;
        }

        if (inSourcesBlock && text !== '') {
          inSourcesBlock = false;
        }
      });
    });
  });
</script>
