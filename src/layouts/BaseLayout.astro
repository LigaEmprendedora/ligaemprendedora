---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Liga Emprendedora | Escuela de emprendimiento online con metáforas de fútbol",
  description = "Liga Emprendedora es una escuela de emprendimiento online que conecta el fútbol con los negocios para ayudarte a lanzar tu proyecto en 90 días.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" href="/favico.png" type="image/png" />
</head>
  <body class="bg-white text-gray-900 antialiased">
    <slot />
  <script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const SCRIPT_URL =
      "https://script.google.com/macros/s/AKfycbz4BZPlvEa1-78yTjp6nBdGH9-UCP02lK2VRrFUA7iSX4It2ODw6nR0_TsMmxabTD52tg/exec";

    const forms = Array.from(document.querySelectorAll("form[name]"));

    forms.forEach((form) => {
      if (form.dataset.bound === "true") return;
      form.dataset.bound = "true";

      const isResourceForm = form.hasAttribute("data-download-link");

      form.addEventListener("submit", async (event) => {
        const formData = new FormData(form);

        if (isResourceForm) {
          event.preventDefault();

          const body = new URLSearchParams();
          for (const [key, value] of formData.entries()) {
            if (typeof value === "string") {
              body.append(key, value);
            }
          }

          try {
            await fetch("/", {
              method: "POST",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
              },
              body: body.toString(),
            });
          } catch (err) {
            console.error("Error enviando a Netlify:", err);
          }

          try {
            await fetch(SCRIPT_URL, {
              method: "POST",
              mode: "no-cors",
              body: formData,
            });
          } catch (err) {
            console.error("Error enviando a Google Sheets:", err);
          }

          const downloadLink = form.dataset.downloadLink;
          const messageEl = form.querySelector("[data-download-message]");

          if (downloadLink && messageEl) {
            messageEl.innerHTML = `
              <strong>¡Listo! Ya puedes descargar tu recurso.</strong><br /><br />
              <a
                href="${downloadLink}"
                target="_blank"
                rel="noopener noreferrer"
                class="underline font-semibold text-[#14532d]"
              >
                Haz clic aquí para descargarlo
              </a>
            `;
            messageEl.classList.remove("hidden");
          }

          form.reset();
          return;
        }

        try {
          fetch(SCRIPT_URL, {
            method: "POST",
            mode: "no-cors",
            body: formData,
          });
        } catch (err) {
          console.error("Error enviando a Google Sheets:", err);
        }
      });
    });
  });
</script>
  </body>
</html>
